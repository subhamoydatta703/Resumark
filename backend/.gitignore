# Dependencies
node_modules/

# Build output
dist/
out/
*.tgz
*.tsbuildinfo
*.js.map

# Environment files
# .env.example is allowed through — it contains only placeholder documentation.
.env
.env.*
!.env.example

# Test and coverage output
coverage/
*.lcov

# Logs and diagnostics
logs/
*.log
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Tool caches
.cache/
.eslintcache

# IDE and operating system files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Generated Prisma clients
# These directories are produced by `bunx prisma generate` and must not be
# committed.  The Dockerfile copies the generated client from the builder
# stage into the production image at build time.
/prisma/generated/
/src/generated/prisma/

# Prisma migrations are version controlled and must not be ignored.
# Apply them in CI or during deployment with `bunx prisma migrate deploy`.

# Bun lockfile policy:
# The text-format bun.lock file is committed.  The legacy binary bun.lockb
# format is excluded because it is not human-readable in diffs.
bun.lockb
