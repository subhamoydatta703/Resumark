# =============================================================================
# 1. Application
# =============================================================================

# Runtime mode used by Express and supporting libraries.
# Use "production" for all deployed environments.
NODE_ENV=production

# TCP port exposed by the API server.
PORT=5000

# Comma-separated list of browser origins allowed by CORS.
# Example: https://app.example.com,https://www.example.com
FRONTEND_URL="your_frontend_url_here"

# =============================================================================
# 2. Database
# =============================================================================

# PostgreSQL connection string used by the API process.
# Include ?sslmode=require for managed database providers.
DATABASE_URL="your_database_url_here"

# PostgreSQL connection string used by the BullMQ worker process.
# May point to the same database as DATABASE_URL; kept separate to allow
# independent pool sizing or read-replica routing in the future.
WORKER_DATABASE_URL="your_worker_database_url_here"

# =============================================================================
# 3. Redis
# =============================================================================

# Redis hostname used for BullMQ job brokering, result caching, and
# rate limiting. Use "redis" when running inside the Docker Compose network.
REDIS_HOST="your_redis_host_here"

# Redis TCP port.
REDIS_PORT=6379

# =============================================================================
# 4. AWS S3
# =============================================================================

# AWS region that contains the resume storage bucket.
# Example: ap-south-1, us-east-1
AWS_REGION="your_aws_region_here"

# AWS access key ID used for S3 upload, download, and delete operations.
# In managed cloud environments, prefer workload identity over static keys.
AWS_ACCESS_KEY_ID="your_aws_access_key_id_here"

# AWS secret access key paired with the access key ID above.
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key_here"

# Name of the S3 bucket that stores uploaded resume PDFs.
AWS_S3_BUCKET_NAME="your_s3_bucket_name_here"

# =============================================================================
# 5. Clerk Authentication
# =============================================================================

# Clerk publishable key associated with the application instance.
# This value is safe to expose in client-side code but is also used
# server-side for token verification initialization.
CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key_here"

# Clerk server secret used for session validation and user lookup.
# Keep this value private; it grants administrative access to your Clerk tenant.
CLERK_SECRET_KEY="your_clerk_secret_key_here"

# Svix signing secret used to verify the authenticity of incoming
# Clerk lifecycle webhook requests (user.created, user.updated, user.deleted).
CLERK_WEBHOOK_SECRET="your_clerk_webhook_secret_here"

# =============================================================================
# 6. Google Gemini
# =============================================================================

# Google Gemini API key used by the analysis worker to generate structured
# resume feedback. This key should have access to the Gemini Pro model.
GEMINI_API_KEY="your_gemini_api_key_here"
